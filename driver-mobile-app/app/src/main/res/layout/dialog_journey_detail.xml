<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_lg">

        <!-- Journey ID -->
        <TextView
            android:id="@+id/tvJourneyId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Journey #1234"
            android:textSize="@dimen/text_title"
            android:textStyle="bold"
            android:textColor="@color/primary" />

        <!-- Date/Time -->
        <TextView
            android:id="@+id/tvDateTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="@dimen/spacing_xs"
            android:text="January 9, 2026 - 08:15 AM"
            android:textSize="@dimen/text_label"
            android:textColor="@color/text_secondary" />

        <!-- Details Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            app:cardElevation="0dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="#F5F5F5"
            app:strokeWidth="1dp"
            app:strokeColor="@color/divider">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_md">

                <!-- Seat Number -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/seat"
                        android:textSize="@dimen/text_label"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tvDetailSeat"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Seat 1"
                        android:textSize="@dimen/text_body"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:layout_marginBottom="@dimen/spacing_sm" />

                <!-- Destination -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/destination"
                        android:textSize="@dimen/text_label"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tvDetailDestination"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chichiri Shopping"
                        android:textSize="@dimen/text_body"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:gravity="end" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:layout_marginBottom="@dimen/spacing_sm" />

                <!-- Boarding Time -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/boarding_time"
                        android:textSize="@dimen/text_label"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tvDetailBoardingTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="08:15 AM"
                        android:textSize="@dimen/text_body"
                        android:textColor="@color/text_primary" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:layout_marginBottom="@dimen/spacing_sm" />

                <!-- Alighting Time -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/alighting_time"
                        android:textSize="@dimen/text_label"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tvDetailAlightingTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="08:23 AM"
                        android:textSize="@dimen/text_body"
                        android:textColor="@color/text_primary" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:layout_marginBottom="@dimen/spacing_sm" />

                <!-- Duration -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/duration"
                        android:textSize="@dimen/text_label"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tvDetailDuration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="8 minutes"
                        android:textSize="@dimen/text_body"
                        android:textColor="@color/text_primary" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:layout_marginBottom="@dimen/spacing_sm" />

                <!-- Distance -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/distance"
                        android:textSize="@dimen/text_label"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tvDetailDistance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2.5 km"
                        android:textSize="@dimen/text_body"
                        android:textColor="@color/text_primary" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:layout_marginBottom="@dimen/spacing_sm" />

                <!-- Fare -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/fare"
                        android:textSize="@dimen/text_label"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tvDetailFare"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1,500 MK"
                        android:textSize="@dimen/text_body_large"
                        android:textStyle="bold"
                        android:textColor="@color/fare_text" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:layout_marginBottom="@dimen/spacing_sm" />

                <!-- Fare Collection Status -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/fare_status"
                        android:textSize="@dimen/text_label"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tvDetailFareStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/fare_collected"
                        android:textSize="@dimen/text_body"
                        android:textStyle="bold"
                        android:textColor="@color/fare_collected" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Close Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnClose"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:text="@string/close"
            android:textSize="@dimen/text_body" />

    </LinearLayout>

</ScrollView>

