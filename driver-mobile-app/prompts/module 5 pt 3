package com.trms.driver.data. repository;

import androidx.lifecycle. LiveData;
import androidx.lifecycle. MutableLiveData;
import com.trms.driver.data. api.JourneyApiService;
import com.trms.driver.data.api.RetrofitClient;
import com. trms.driver.data.local.TokenManager;
import com.trms.driver.data.model.Journey;
import com.trms. driver.data.model.JourneyDetailResponse;
import com.trms.driver.data.model.JourneyHistoryResponse;
import com.trms.driver.data.model.Statistics;
import com.trms. driver.data.model.StatisticsResponse;
import java.util.List;
import retrofit2.Call;
import retrofit2.Callback;
import retrofit2.Response;

public class JourneyHistoryRepository {

    private JourneyApiService apiService;
    private TokenManager tokenManager;

    public JourneyHistoryRepository(TokenManager tokenManager) {
        this.apiService = RetrofitClient.getInstance().getJourneyApi();
        this.tokenManager = tokenManager;
    }

    /**
     * Get journey history with pagination and filters
     */
    public LiveData<Result<JourneyHistoryResponse>> getJourneys(String vehicleId, int page,
                                                                 int limit, String startDate,
                                                                 String endDate, String search) {
        MutableLiveData<Result<JourneyHistoryResponse>> result = new MutableLiveData<>();

        String token = tokenManager.getToken();
        if (token == null) {
            result.setValue(Result.error("Authentication required"));
            return result;
        }

        apiService.getJourneys(vehicleId, page, limit, startDate, endDate, search, "Bearer " + token)
            .enqueue(new Callback<JourneyHistoryResponse>() {
                @Override
                public void onResponse(Call<JourneyHistoryResponse> call,
                                      Response<JourneyHistoryResponse> response) {
                    if (response.isSuccessful() && response.body() != null) {
                        result.setValue(Result.success(response.body()));
                    } else {
                        String error = "Failed to load journeys";
                        if (response.code() == 401) {
                            error = "Session expired. Please login again.";
                        } else if (response.code() == 404) {
                            error = "No journeys found";
                        } else if (response.code() >= 500) {
                            error = "Server error. Please try again. ";
                        }
                        result.setValue(Result.error(error));
                    }
                }

                @Override
                public void onFailure(Call<JourneyHistoryResponse> call, Throwable t) {
                    String error = "Network error";
                    if (t. getMessage() != null) {
                        if (t.getMessage().contains("timeout")) {
                            error = "Connection timeout. Check your internet. ";
                        } else if (t.getMessage().contains("Unable to resolve host")) {
                            error = "No internet connection";
                        } else {
                            error = t.getMessage();
                        }
                    }
                    result. setValue(Result.error(error));
                }
            });

        return result;
    }

    /**
     * Get journey detail by ID
     */
    public LiveData<Result<Journey>> getJourneyDetail(int journeyId) {
        MutableLiveData<Result<Journey>> result = new MutableLiveData<>();

        String token = tokenManager.getToken();
        if (token == null) {
            result.setValue(Result. error("Authentication required"));
            return result;
        }

        apiService.getJourneyDetail(journeyId, "Bearer " + token)
            .enqueue(new Callback<JourneyDetailResponse>() {
                @Override
                public void onResponse(Call<JourneyDetailResponse> call,
                                      Response<JourneyDetailResponse> response) {
                    if (response.isSuccessful() && response.body() != null) {
                        result.setValue(Result.success(response.body().getJourney()));
                    } else {
                        String error = "Failed to load journey details";
                        if (response. code() == 401) {
                            error = "Session expired";
                        } else if (response.code() == 404) {
                            error = "Journey not found";
                        }
                        result.setValue(Result.error(error));
                    }
                }

                @Override
                public void onFailure(Call<JourneyDetailResponse> call, Throwable t) {
                    result.setValue(Result.error("Network error:  " + t.getMessage()));
                }
            });

        return result;
    }

    /**
     * Get statistics for date range
     */
    public LiveData<Result<StatisticsResponse>> getStatistics(String vehicleId,
                                                               String startDate,
                                                               String endDate) {
        MutableLiveData<Result<StatisticsResponse>> result = new MutableLiveData<>();

        String token = tokenManager.getToken();
        if (token == null) {
            result.setValue(Result.error("Authentication required"));
            return result;
        }

        apiService.getStatistics(vehicleId, startDate, endDate, "Bearer " + token)
            .enqueue(new Callback<StatisticsResponse>() {
                @Override
                public void onResponse(Call<StatisticsResponse> call,
                                      Response<StatisticsResponse> response) {
                    if (response. isSuccessful() && response.body() != null) {
                        result.setValue(Result.success(response.body()));
                    } else {
                        String error = "Failed to load statistics";
                        if (response.code() == 401) {
                            error = "Session expired";
                        }
                        result.setValue(Result.error(error));
                    }
                }

                @Override
                public void onFailure(Call<StatisticsResponse> call, Throwable t) {
                    result.setValue(Result.error("Network error: " + t.getMessage()));
                }
            });

        return result;
    }

    // Result wrapper
    public static class Result<T> {
        private T data;
        private String error;
        private boolean success;

        private Result(T data, String error, boolean success) {
            this.data = data;
            this.error = error;
            this.success = success;
        }

        public static <T> Result<T> success(T data) {
            return new Result<>(data, null, true);
        }

        public static <T> Result<T> error(String error) {
            return new Result<>(null, error, false);
        }

        public T getData() { return data; }
        public String getError() { return error; }
        public boolean isSuccess() { return success; }
    }
}
