<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Light Theme -->
    <style name="Theme.TRMSOwnerApp" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/primary_light</item>
        <item name="colorSecondaryVariant">@color/primary_dark</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSurface">@color/background</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorError">@color/danger</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/primary_dark</item>
        <!-- Window background -->
        <item name="android:windowBackground">@color/background</item>
        <!-- Text colors -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:fontFamily">@font/inter</item>
        <item name="fontFamily">@font/inter</item>
        <!-- Card background -->
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="materialCardViewStyle">@style/Widget.TRMSOwner.CardView</item>
        <item name="materialButtonStyle">@style/Widget.TRMSOwner.Button.Primary</item>
        <item name="textInputStyle">@style/Widget.TRMSOwner.TextInputLayout</item>
        <item name="editTextStyle">@style/Widget.TRMSOwner.TextInputEditText</item>
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.TRMSOwner.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.TRMSOwner.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.TRMSOwner.Large</item>
    </style>

    <style name="ShapeAppearance.TRMSOwner.Small" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">14dp</item>
    </style>

    <style name="ShapeAppearance.TRMSOwner.Medium" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">14dp</item>
    </style>

    <style name="ShapeAppearance.TRMSOwner.Large" parent="ShapeAppearance.MaterialComponents.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">20dp</item>
    </style>

    <style name="Widget.TRMSOwner.CardView" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">6dp</item>
        <item name="cardUseCompatPadding">true</item>
        <item name="cardBackgroundColor">@color/surface</item>
    </style>

    <style name="Widget.TRMSOwner.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">14dp</item>
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="rippleColor">@color/surface_tint</item>
    </style>

    <style name="Widget.TRMSOwner.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.FilledBox">
        <item name="boxBackgroundColor">@color/input_background</item>
        <item name="boxStrokeColor">@color/primary</item>
        <item name="boxStrokeWidth">0dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="boxCornerRadiusTopStart">14dp</item>
        <item name="boxCornerRadiusTopEnd">14dp</item>
        <item name="boxCornerRadiusBottomStart">14dp</item>
        <item name="boxCornerRadiusBottomEnd">14dp</item>
        <item name="hintTextColor">@color/text_secondary</item>
    </style>

    <style name="Widget.TRMSOwner.TextInputEditText" parent="Widget.MaterialComponents.TextInputEditText.FilledBox">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
    </style>
</resources>
