<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_lg">

        <!-- Icon -->
        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_passenger_alighting"
            app:tint="@color/primary"
            android:contentDescription="@string/alighting_icon" />

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="@dimen/spacing_md"
            android:text="@string/confirm_alighting"
            android:textSize="@dimen/text_title"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="@dimen/spacing_xs"
            android:text="@string/alighting_subtitle"
            android:textSize="@dimen/text_label"
            android:textColor="@color/text_secondary"
            android:gravity="center" />

        <!-- Journey Summary Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            app:cardElevation="0dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="#F5F5F5"
            app:strokeWidth="1dp"
            app:strokeColor="@color/divider">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_md">

                <!-- Seat Number -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="@dimen/spacing_sm">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/seat"
                        android:textSize="@dimen/text_label"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tvSeatNumber"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Seat 1"
                        android:textSize="@dimen/text_body"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginBottom="@dimen/spacing_sm" />

                <!-- Destination -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="@dimen/spacing_sm">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/destination"
                        android:textSize="@dimen/text_label"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tvDestination"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chichiri Shopping"
                        android:textSize="@dimen/text_body"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:gravity="end" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginBottom="@dimen/spacing_sm" />

                <!-- Fare -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="@dimen/spacing_sm">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/fare"
                        android:textSize="@dimen/text_label"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tvFare"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1,500 MK"
                        android:textSize="@dimen/text_fare_amount"
                        android:textStyle="bold"
                        android:textColor="@color/fare_text" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginBottom="@dimen/spacing_sm" />

                <!-- Duration -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="@dimen/spacing_sm">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/duration"
                        android:textSize="@dimen/text_label"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tvDuration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="8 minutes"
                        android:textSize="@dimen/text_body"
                        android:textColor="@color/text_primary" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginBottom="@dimen/spacing_sm" />

                <!-- Distance -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/distance"
                        android:textSize="@dimen/text_label"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tvDistance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2.5 km"
                        android:textSize="@dimen/text_body"
                        android:textColor="@color/text_primary" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Question: Did Passenger Alight? -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:text="@string/did_passenger_alight"
            android:textSize="@dimen/text_body_large"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:gravity="center" />

        <!-- Alighting Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:orientation="horizontal"
            android:gravity="center">

            <!-- Missed Stop Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMissedStop"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="@dimen/alighting_button_height"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:text="@string/missed_stop"
                android:textSize="@dimen/text_body"
                app:icon="@drawable/ic_missed_stop"
                app:iconGravity="top"
                app:iconSize="32dp"
                app:strokeColor="@color/missed_stop"
                android:textColor="@color/missed_stop" />

            <!-- Yes Alighted Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnYesAlighted"
                android:layout_width="0dp"
                android:layout_height="@dimen/alighting_button_height"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/spacing_sm"
                android:text="@string/yes_alighted"
                android:textSize="@dimen/text_body"
                android:backgroundTint="@color/alighting_success"
                app:icon="@drawable/ic_check_circle_outline"
                app:iconGravity="top"
                app:iconSize="32dp" />

        </LinearLayout>

        <!-- Fare Collection Section (Initially Hidden) -->
        <LinearLayout
            android:id="@+id/fareCollectionSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Question: Fare Collected? -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/was_fare_collected"
                android:textSize="@dimen/text_body_large"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:gravity="center" />

            <!-- Fare Collection Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:orientation="horizontal"
                android:gravity="center">

                <!-- No Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFareNo"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/touch_target_lg"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/spacing_sm"
                    android:text="@string/no"
                    android:textSize="@dimen/text_body"
                    app:strokeColor="@color/fare_not_collected"
                    android:textColor="@color/fare_not_collected" />

                <!-- Yes Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFareYes"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/touch_target_lg"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/spacing_sm"
                    android:text="@string/yes"
                    android:textSize="@dimen/text_body"
                    android:backgroundTint="@color/fare_collected" />

            </LinearLayout>

        </LinearLayout>

        <!-- Cancel Button (Bottom) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancel"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="@dimen/spacing_md"
            android:text="@string/cancel"
            android:textSize="@dimen/text_body" />

    </LinearLayout>

</ScrollView>

