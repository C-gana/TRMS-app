<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:elevation="4dp"
        app:elevation="4dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/primary"
            app:title="@string/duty_status"
            app:titleTextColor="@android:color/white"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:menu="@menu/menu_duty_status" />
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Main Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_md">

            <!-- Driver Info Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/driverInfoCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardElevation="2dp"
                app:cardCornerRadius="12dp"
                android:layout_marginBottom="@dimen/spacing_md">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="@dimen/spacing_md"
                    android:gravity="center_vertical">

                    <!-- Driver Avatar -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        app:cardCornerRadius="28dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/primary_light">

                        <TextView
                            android:id="@+id/tvDriverInitial"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="J"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary" />

                    </com.google.android.material.card.MaterialCardView>

                    <!-- Driver Details -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/spacing_md"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvWelcome"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/welcome_driver"
                            android:textSize="@dimen/text_caption"
                            android:textColor="@color/text_secondary" />

                        <TextView
                            android:id="@+id/tvDriverName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="John Banda"
                            android:textSize="@dimen/text_body_large"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:layout_marginTop="@dimen/spacing_xs" />

                        <TextView
                            android:id="@+id/tvDriverPhone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="+265991234567"
                            android:textSize="@dimen/text_label"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:drawableStart="@drawable/ic_phone_small"
                            android:drawablePadding="@dimen/spacing_xs"
                            android:drawableTint="@color/text_secondary" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Vehicle Info Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/vehicleInfoCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardElevation="2dp"
                app:cardCornerRadius="12dp"
                android:layout_marginBottom="@dimen/spacing_md">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/your_vehicle"
                        android:textSize="@dimen/text_label"
                        android:textColor="@color/text_secondary"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <androidx.appcompat.widget.AppCompatImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            app:srcCompat="@drawable/ic_vehicle"
                            app:tint="@color/primary"
                            android:contentDescription="@string/vehicle_icon" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="@dimen/spacing_md"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvVehicleId"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="TRM-BT-001"
                                android:textSize="@dimen/text_body_large"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary" />

                            <TextView
                                android:id="@+id/tvVehicleRegistration"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="MJ 1234"
                                android:textSize="@dimen/text_body"
                                android:textColor="@color/text_secondary"
                                android:layout_marginTop="@dimen/spacing_xs" />

                        </LinearLayout>

                        <!-- Status Indicator -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="@drawable/status_badge_background"
                            android:padding="@dimen/spacing_sm">

                            <View
                                android:id="@+id/statusIndicator"
                                android:layout_width="8dp"
                                android:layout_height="8dp"
                                android:background="@drawable/circle_shape"
                                android:backgroundTint="@color/success" />

                            <TextView
                                android:id="@+id/tvVehicleStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/spacing_xs"
                                android:text="@string/online"
                                android:textSize="@dimen/text_caption"
                                android:textStyle="bold"
                                android:textColor="@color/success" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Duty Status Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/dutyStatusCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardElevation="4dp"
                app:cardCornerRadius="16dp"
                android:layout_marginBottom="@dimen/spacing_md"
                app:strokeWidth="2dp"
                app:strokeColor="@color/divider">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg"
                    android:gravity="center">

                    <!-- Duty Status Icon & Text (OFF DUTY) -->
                    <LinearLayout
                        android:id="@+id/offDutyContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:visibility="visible">

                        <ImageView
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:src="@drawable/ic_duty_off"
                            app:tint="@color/off_duty"
                            android:contentDescription="@string/off_duty_icon" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_md"
                            android:text="@string/you_are_off_duty"
                            android:textSize="@dimen/text_headline"
                            android:textStyle="bold"
                            android:textColor="@color/off_duty" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:text="@string/tap_to_start"
                            android:textSize="@dimen/text_body"
                            android:textColor="@color/text_secondary"
                            android:gravity="center" />

                    </LinearLayout>

                    <!-- Duty Status Icon & Text (ON DUTY) -->
                    <LinearLayout
                        android:id="@+id/onDutyContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:visibility="gone">

                        <ImageView
                            android:id="@+id/ivDutyOn"
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:src="@drawable/ic_duty_on"
                            app:tint="@color/on_duty"
                            android:contentDescription="@string/on_duty_icon" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_md"
                            android:text="@string/you_are_on_duty"
                            android:textSize="@dimen/text_headline"
                            android:textStyle="bold"
                            android:textColor="@color/on_duty" />

                        <TextView
                            android:id="@+id/tvDutyStartTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:text="Started at 08:15 AM"
                            android:textSize="@dimen/text_body"
                            android:textColor="@color/text_secondary" />

                        <TextView
                            android:id="@+id/tvDutyDuration"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:text="Duration: 2h 30min"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary" />

                    </LinearLayout>

                    <!-- Duty Toggle Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnToggleDuty"
                        android:layout_width="match_parent"
                        android:layout_height="88dp"
                        android:layout_marginTop="@dimen/spacing_lg"
                        android:text="@string/start_duty"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        app:cornerRadius="16dp"
                        app:elevation="6dp"
                        app:icon="@drawable/ic_play"
                        app:iconGravity="textStart"
                        app:iconSize="32dp"
                        app:iconPadding="@dimen/spacing_md"
                        style="@style/Widget.MaterialComponents.Button" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Today's Summary Card (Only visible when ON DUTY) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/summaryCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardElevation="2dp"
                app:cardCornerRadius="12dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_summary"
                            app:tint="@color/primary"
                            android:contentDescription="@string/summary_icon" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_sm"
                            android:text="@string/todays_summary"
                            android:textSize="@dimen/text_title"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary" />

                    </LinearLayout>

                    <!-- Stats Grid -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:orientation="vertical">

                        <!-- Passengers -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingTop="@dimen/spacing_sm"
                            android:paddingBottom="@dimen/spacing_sm">

                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:src="@drawable/ic_passengers"
                                app:tint="@color/info"
                                android:contentDescription="@string/passengers_icon" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="@dimen/spacing_md"
                                android:text="@string/passengers_today"
                                android:textSize="@dimen/text_body"
                                android:textColor="@color/text_secondary" />

                            <TextView
                                android:id="@+id/tvPassengerCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="12"
                                android:textSize="@dimen/text_title"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary" />

                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/divider" />

                        <!-- Active Seats -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingTop="@dimen/spacing_sm"
                            android:paddingBottom="@dimen/spacing_sm">

                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:src="@drawable/ic_seats"
                                app:tint="@color/success"
                                android:contentDescription="@string/seats_icon" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="@dimen/spacing_md"
                                android:text="@string/active_passengers"
                                android:textSize="@dimen/text_body"
                                android:textColor="@color/text_secondary" />

                            <TextView
                                android:id="@+id/tvActiveSeats"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="2/4"
                                android:textSize="@dimen/text_title"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary" />

                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/divider" />

                        <!-- Revenue -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingTop="@dimen/spacing_sm"
                            android:paddingBottom="@dimen/spacing_sm">

                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:src="@drawable/ic_money"
                                app:tint="@color/accent"
                                android:contentDescription="@string/revenue_icon" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="@dimen/spacing_md"
                                android:text="@string/revenue_today"
                                android:textSize="@dimen/text_body"
                                android:textColor="@color/text_secondary" />

                            <TextView
                                android:id="@+id/tvRevenue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="18,000 MK"
                                android:textSize="@dimen/text_title"
                                android:textStyle="bold"
                                android:textColor="@color/accent" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Loading Overlay -->
    <FrameLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            app:cardElevation="8dp"
            app:cardCornerRadius="16dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_xl"
                android:gravity="center">

                <ProgressBar
                    style="?android:attr/progressBarStyle"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:indeterminateTint="@color/primary" />

                <TextView
                    android:id="@+id/tvLoadingMessage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:text="@string/updating_status"
                    android:textSize="@dimen/text_body"
                    android:textColor="@color/text_primary" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>