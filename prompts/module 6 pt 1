package com.trms. driver.data.local;

import android.content.Context;
import androidx.room.Database;
import androidx.room.Room;
import androidx.room.RoomDatabase;
import com.trms.driver.data. local.dao.DashboardCacheDao;
import com.trms.driver.data.local. dao.DestinationCacheDao;
import com.trms.driver.data.local.dao.SyncQueueDao;
import com.trms.driver. data.local.entity.DashboardCacheEntity;
import com.trms.driver.data. local.entity.DestinationCacheEntity;
import com. trms.driver.data.local.entity.SyncQueueEntity;

@Database(
    entities = {
        DashboardCacheEntity. class,
        DestinationCacheEntity.class,
        SyncQueueEntity.class
    },
    version = 1,
    exportSchema = false
)
public abstract class TRMSDatabase extends RoomDatabase {

    private static volatile TRMSDatabase INSTANCE;

    public abstract DashboardCacheDao dashboardCacheDao();
    public abstract DestinationCacheDao destinationCacheDao();
    public abstract SyncQueueDao syncQueueDao();

    public static TRMSDatabase getInstance(Context context) {
        if (INSTANCE == null) {
            synchronized (TRMSDatabase.class) {
                if (INSTANCE == null) {
                    INSTANCE = Room.databaseBuilder(
                        context.getApplicationContext(),
                        TRMSDatabase.class,
                        "trms_driver_database"
                    ).build();
                }
            }
        }
        return INSTANCE;
    }
}
