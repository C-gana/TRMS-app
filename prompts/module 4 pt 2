## Feature 5: Alighting Repository

**File:** `com.trms.driver.data.repository.AlightingRepository. java`

```java
package com.trms.driver.data. repository;

import androidx.lifecycle.LiveData;
import androidx.lifecycle. MutableLiveData;
import com.trms.driver.data. api.DashboardApiService;
import com.trms.driver. data.api.RetrofitClient;
import com.trms.driver.data.local.TokenManager;
import com.trms. driver.data.model.AlightingRequest;
import com.trms.driver.data.model. AlightingResponse;
import com.trms.driver.data. model.Location;
import com.trms. driver.data.model.MissedStopRequest;
import com.trms.driver.data. model.MissedStopResponse;
import retrofit2.Call;
import retrofit2.Callback;
import retrofit2.Response;

public class AlightingRepository {

    private DashboardApiService apiService;
    private TokenManager tokenManager;

    public AlightingRepository(TokenManager tokenManager) {
        this.apiService = RetrofitClient.getInstance().getDashboardApi();
        this.tokenManager = tokenManager;
    }

    /**
     * Record passenger alighting
     */
    public LiveData<Result<AlightingResponse>> recordAlighting(String vehicleId, int journeyId,
                                                                int seatNumber, Location location,
                                                                boolean fareCollected, boolean missedStop) {
        MutableLiveData<Result<AlightingResponse>> result = new MutableLiveData<>();

        String token = tokenManager.getToken();
        if (token == null) {
            result.setValue(Result.error("Authentication required"));
            return result;
        }

        AlightingRequest request = new AlightingRequest(vehicleId, journeyId, seatNumber,
                                                        location, fareCollected, missedStop);

        apiService.recordAlighting(request, "Bearer " + token)
            .enqueue(new Callback<AlightingResponse>() {
                @Override
                public void onResponse(Call<AlightingResponse> call, Response<AlightingResponse> response) {
                    if (response.isSuccessful() && response.body() != null) {
                        AlightingResponse alightingResponse = response.body();
                        if (alightingResponse.isSuccess()) {
                            result.setValue(Result.success(alightingResponse));
                        } else {
                            result.setValue(Result.error(alightingResponse. getMessage()));
                        }
                    } else {
                        String error = "Failed to record alighting";
                        if (response.code() == 400) {
                            error = "Invalid journey data";
                        } else if (response.code() == 401) {
                            error = "Session expired. Please login again. ";
                        } else if (response.code() == 404) {
                            error = "Journey not found";
                        } else if (response.code() == 409) {
                            error = "Journey already completed";
                        } else if (response.code() >= 500) {
                            error = "Server error. Please try again.";
                        }
                        result.setValue(Result.error(error));
                    }
                }

                @Override
                public void onFailure(Call<AlightingResponse> call, Throwable t) {
                    String error = "Network error";
                    if (t. getMessage() != null) {
                        if (t.getMessage().contains("timeout")) {
                            error = "Connection timeout.  Check your internet. ";
                        } else if (t.getMessage().contains("Unable to resolve host")) {
                            error = "No internet connection";
                        } else {
                            error = t.getMessage();
                        }
                    }
                    result. setValue(Result.error(error));
                }
            });

        return result;
    }

    /**
     * Report missed stop
     */
    public LiveData<Result<MissedStopResponse>> reportMissedStop(String vehicleId, int journeyId,
                                                                  int seatNumber, Location location,
                                                                  String notes) {
        MutableLiveData<Result<MissedStopResponse>> result = new MutableLiveData<>();

        String token = tokenManager.getToken();
        if (token == null) {
            result.setValue(Result.error("Authentication required"));
            return result;
        }

        MissedStopRequest request = new MissedStopRequest(vehicleId, journeyId, seatNumber,
                                                          location, notes);

        apiService.reportMissedStop(request, "Bearer " + token)
            .enqueue(new Callback<MissedStopResponse>() {
                @Override
                public void onResponse(Call<MissedStopResponse> call, Response<MissedStopResponse> response) {
                    if (response.isSuccessful() && response.body() != null) {
                        MissedStopResponse missedResponse = response.body();
                        if (missedResponse.isSuccess()) {
                            result.setValue(Result.success(missedResponse));
                        } else {
                            result.setValue(Result. error(missedResponse.getMessage()));
                        }
                    } else {
                        String error = "Failed to report missed stop";
                        if (response.code() == 400) {
                            error = "Invalid data";
                        } else if (response.code() == 401) {
                            error = "Session expired";
                        } else if (response.code() == 404) {
                            error = "Journey not found";
                        }
                        result.setValue(Result.error(error));
                    }
                }

                @Override
                public void onFailure(Call<MissedStopResponse> call, Throwable t) {
                    result.setValue(Result.error("Network error:  " + t.getMessage()));
                }
            });

        return result;
    }

    // Result wrapper
    public static class Result<T> {
        private T data;
        private String error;
        private boolean success;

        private Result(T data, String error, boolean success) {
            this. data = data;
            this. error = error;
            this. success = success;
        }

        public static <T> Result<T> success(T data) {
            return new Result<>(data, null, true);
        }

        public static <T> Result<T> error(String error) {
            return new Result<>(null, error, false);
        }

        public T getData() { return data; }
        public String getError() { return error; }
        public boolean isSuccess() { return success; }
    }
}
```

