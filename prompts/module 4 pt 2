private void getCurrentLocationAndReportMissed(int journeyId, int seatNumber, String notes) {
    showLoading(true);

    fusedLocationClient.getCurrentLocation(Priority.PRIORITY_HIGH_ACCURACY, null)
        .addOnSuccessListener(this, location -> {
            com.trms.driver.data.model.Location currentLocation;
            if (location != null) {
                currentLocation = new com.trms.driver. data.model.Location(
                    location.getLatitude(),
                    location.getLongitude()
                );
            } else {
                currentLocation = new com. trms.driver.data.model.Location(0.0, 0.0);
            }
            performReportMissed(journeyId, seatNumber, notes, currentLocation);
