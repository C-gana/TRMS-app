        .addOnSuccessListener(this, location -> {
            com.trms.driver.data. model.Location alightingLocation;
            if (location != null) {
                alightingLocation = new com.trms.driver. data.model.Location(
                    location.getLatitude(),
                    location.getLongitude()
                );
            } else {
