package com.trms.driver. ui.alighting;

import android.app.Dialog;
import android.os.Bundle;
import android.view.LayoutInflater;
import android.view.View;
import android.widget.LinearLayout;
import android.widget. TextView;
import androidx.annotation.NonNull;
import androidx.appcompat.app.AlertDialog;
import androidx.fragment. app.DialogFragment;
import com.google.android.material.button.MaterialButton;
import com. google.android.material.dialog.MaterialAlertDialogBuilder;
import com.trms.driver.R;
import com.trms.driver.data.model. Seat;
import com.trms. driver.utils.DateUtils;
import java.util. Locale;

public class AlightingConfirmationDialog extends DialogFragment {

    public interface AlightingDialogListener {
        void onConfirmAlighting(int seatNumber, int journeyId, boolean fareCollected);
        void onMissedStop(int seatNumber, int journeyId);
    }

    private AlightingDialogListener listener;
    private Seat seat;
    private boolean fareCollected = false;
    private boolean fareQuestionAnswered = false;

    public static AlightingConfirmationDialog newInstance(Seat seat) {
        AlightingConfirmationDialog dialog = new AlightingConfirmationDialog();
        Bundle args = new Bundle();
        // Pass seat data as separate parameters
        args.putInt("seat_number", seat.getSeat_number());
        args.putInt("journey_id", seat.getJourney_id());
        args.putString("destination", seat.getDestination());
        args.putInt("fare", seat.getFare());
        args.putString("boarding_time", seat.getBoarding_time());
        args.putDouble("distance_km", seat.getDistance_to_destination() != null ?
                       seat.getDistance_to_destination() : 0.0);
        dialog.setArguments(args);
        return dialog;
    }

    public void setListener(AlightingDialogListener listener) {
        this.listener = listener;
    }

    @NonNull
    @Override
    public Dialog onCreateDialog(Bundle savedInstanceState) {
        // Reconstruct seat from arguments
        seat = new Seat();
        if (getArguments() != null) {
            seat.setSeat_number(getArguments().getInt("seat_number"));
            seat.setJourney_id(getArguments().getInt("journey_id"));
            seat.setDestination(getArguments().getString("destination"));
            seat.setFare(getArguments().getInt("fare"));
            seat.setBoarding_time(getArguments().getString("boarding_time"));
            seat.setDistance_to_destination(getArguments().getDouble("distance_km"));
        }

        // Inflate layout
        LayoutInflater inflater = requireActivity().getLayoutInflater();
        View view = inflater.inflate(R.layout.dialog_alighting_confirmation, null);

        // Setup views
        TextView tvSeatNumber = view.findViewById(R.id.tvSeatNumber);
        TextView tvDestination = view.findViewById(R. id.tvDestination);
        TextView tvFare = view.findViewById(R.id.tvFare);
        TextView tvDuration = view.findViewById(R.id.tvDuration);
        TextView tvDistance = view.findViewById(R.id.tvDistance);
        MaterialButton btnYesAlighted = view.findViewById(R.id.btnYesAlighted);
        MaterialButton btnMissedStop = view.findViewById(R.id.btnMissedStop);
        MaterialButton btnCancel = view.findViewById(R. id.btnCancel);
        LinearLayout fareCollectionSection = view.findViewById(R.id.fareCollectionSection);
        MaterialButton btnFareYes = view.findViewById(R. id.btnFareYes);
        MaterialButton btnFareNo = view.findViewById(R.id.btnFareNo);

        // Set data
        tvSeatNumber.setText(getString(R.string.seat_number_format, seat.getSeat_number()));
        tvDestination.setText(seat.getDestination());
        tvFare.setText(String.format(Locale.getDefault(), "%,d MK", seat.getFare()));

        // Calculate duration
        if (seat.getBoarding_time() != null) {
            String duration = DateUtils.calculateDuration(seat.getBoarding_time());
            tvDuration.setText(duration);
        } else {
            tvDuration. setText("N/A");
        }

        // Set distance
        if (seat.getDistance_to_destination() != null) {
            tvDistance.setText(String.format(Locale.getDefault(), "%.1f km",
                                            seat.getDistance_to_destination()));
        } else {
            tvDistance.setText("N/A");
        }

        // Build dialog
        MaterialAlertDialogBuilder builder = new MaterialAlertDialogBuilder(requireContext())
                .setView(view)
                .setCancelable(true);

        AlertDialog dialog = builder.create();

        // Button listeners
        btnYesAlighted. setOnClickListener(v -> {
            // Show fare collection question
            v.setEnabled(false);
            btnMissedStop.setEnabled(false);
            fareCollectionSection.setVisibility(View.VISIBLE);
        });

        btnMissedStop.setOnClickListener(v -> {
            dialog.dismiss();
            if (listener != null) {
                listener.onMissedStop(seat.getSeat_number(), seat.getJourney_id());
            }
        });

        btnFareYes.setOnClickListener(v -> {
            fareCollected = true;
            fareQuestionAnswered = true;
            dialog.dismiss();
            if (listener != null) {
                listener. onConfirmAlighting(seat. getSeat_number(), seat.getJourney_id(), true);
            }
        });

        btnFareNo. setOnClickListener(v -> {
            fareCollected = false;
            fareQuestionAnswered = true;
            dialog.dismiss();
            if (listener != null) {
                listener.onConfirmAlighting(seat.getSeat_number(), seat.getJourney_id(), false);
            }
        });

        btnCancel.setOnClickListener(v -> dialog.dismiss());

        return dialog;
    }
}
