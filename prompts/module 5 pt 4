## Feature 12: Statistics Activity

**File:** `com.trms.driver.ui. history.StatisticsActivity.java`

```java
package com.trms.driver.ui.history;

import android.os.Bundle;
import android.view.View;
import android.widget.FrameLayout;
import android.widget.TextView;
import android.widget.Toast;
import androidx.annotation.NonNull;
import androidx. appcompat.app.AppCompatActivity;
import androidx.lifecycle.LiveData;
import com.google.android.material.appbar.MaterialToolbar;
import com.google.android.material.tabs.TabLayout;
import com. trms.driver.R;
import com.trms.driver. data.local.TokenManager;
import com.trms.driver. data.model.Statistics;
import com.trms. driver.data.model.StatisticsResponse;
import com.trms. driver.data.repository.JourneyHistoryRepository;
import java.text.SimpleDateFormat;
import java.util.Calendar;
import java.util. Locale;

public class StatisticsActivity extends AppCompatActivity {

    // UI Components
    private MaterialToolbar toolbar;
    private TabLayout tabLayoutPeriod;
    private TextView tvTotalJourneys, tvTotalRevenue, tvTotalDistance, tvAverageFare;
    private TextView tvTotalDuration, tvFareCollectionRate, tvFaresCollected, tvBusiestDestination;
    private FrameLayout loadingOverlay;

    // Data
    private JourneyHistoryRepository repository;
    private TokenManager tokenManager;
    private String vehicleId;

    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);
        setContentView(R.layout.activity_statistics);

        // Initialize
        tokenManager = new TokenManager(this);
        vehicleId = tokenManager.getDriver().getVehicleId();
        repository = new JourneyHistoryRepository(tokenManager);

        // Initialize views
        initializeViews();

        // Setup toolbar
        setupToolbar();

        // Setup tabs
        setupTabs();

        // Load today's statistics by default
        loadStatistics("today");
    }

    private void initializeViews() {
        toolbar = findViewById(R.id.toolbar);
        tabLayoutPeriod = findViewById(R.id.tabLayoutPeriod);
        tvTotalJourneys = findViewById(R.id. tvTotalJourneys);
        tvTotalRevenue = findViewById(R.id.tvTotalRevenue);
        tvTotalDistance = findViewById(R.id. tvTotalDistance);
        tvAverageFare = findViewById(R.id.tvAverageFare);
        tvTotalDuration = findViewById(R.id.tvTotalDuration);
        tvFareCollectionRate = findViewById(R.id.tvFareCollectionRate);
        tvFaresCollected = findViewById(R.id.tvFaresCollected);
        tvBusiestDestination = findViewById(R. id.tvBusiestDestination);
        loadingOverlay = findViewById(R.id.loadingOverlay);
    }

    private void setupToolbar() {
        setSupportActionBar(toolbar);
        if (getSupportActionBar() != null) {
            getSupportActionBar().setDisplayHomeAsUpEnabled(true);
        }
        toolbar.setNavigationOnClickListener(v -> onBackPressed());
    }

    private void setupTabs() {
        tabLayoutPeriod.addTab(tabLayoutPeriod.newTab().setText(R.string.today));
        tabLayoutPeriod.addTab(tabLayoutPeriod.newTab().setText(R.string.yesterday));
        tabLayoutPeriod.addTab(tabLayoutPeriod.newTab().setText(R.string.this_week));
        tabLayoutPeriod.addTab(tabLayoutPeriod. newTab().setText(R.string.this_month));

        tabLayoutPeriod.addOnTabSelectedListener(new TabLayout.OnTabSelectedListener() {
            @Override
            public void onTabSelected(TabLayout.Tab tab) {
                String period;
                switch (tab.getPosition()) {
                    case 0: period = "today"; break;
                    case 1: period = "yesterday"; break;
                    case 2: period = "week"; break;
                    case 3: period = "month"; break;
                    default: period = "today";
                }
                loadStatistics(period);
            }

            @Override
            public void onTabUnselected(TabLayout.Tab tab) {}

            @Override
            public void onTabReselected(TabLayout. Tab tab) {}
        });
    }

    private void loadStatistics(String period) {
        showLoading(true);

        SimpleDateFormat sdf = new SimpleDateFormat("yyyy-MM-dd'T'HH:mm:ss'Z'", Locale.getDefault());
        Calendar calendar = Calendar. getInstance();

        String endDate = sdf.format(calendar.getTime());
        String startDate;

        switch (period) {
            case "today":
                calendar.set(Calendar.HOUR_OF_DAY, 0);
                calendar.set(Calendar.MINUTE, 0);
                calendar. set(Calendar.SECOND, 0);
                startDate = sdf.format(calendar.getTime());
                break;

            case "yesterday":
                calendar.add(Calendar.DAY_OF_MONTH, -1);
                calendar.set(Calendar.HOUR_OF_DAY, 0);
                calendar.set(Calendar. MINUTE, 0);
                calendar.set(Calendar.SECOND, 0);
                startDate = sdf.format(calendar. getTime());

                calendar.set(Calendar.HOUR_OF_DAY, 23);
                calendar.set(Calendar.MINUTE, 59);
                calendar. set(Calendar.SECOND, 59);
                endDate = sdf.format(calendar.getTime());
                break;

            case "week":
                calendar.add(Calendar.DAY_OF_MONTH, -7);
                startDate = sdf.format(calendar.getTime());
                break;

            case "month":
                calendar.add(Calendar. MONTH, -1);
                startDate = sdf.format(calendar.getTime());
                break;

            default:
                return;
        }

        LiveData<JourneyHistoryRepository.Result<StatisticsResponse>> result =
            repository.getStatistics(vehicleId, startDate, endDate);

        result. observeForever(statsResult -> {
            showLoading(false);

            if (statsResult.isSuccess()) {
                displayStatistics(statsResult.getData().getStatistics());
            } else {
                Toast.makeText(this, statsResult.getError(), Toast.LENGTH_SHORT).show();
            }
        });
    }

    private void displayStatistics(Statistics stats) {
        // Summary Cards
        tvTotalJourneys.setText(String.valueOf(stats.getTotal_journeys()));
        tvTotalRevenue.setText(String.format(Locale.getDefault(), "%,d", stats.getTotal_revenue()));
        tvTotalDistance.setText(String.format(Locale.getDefault(), "%.1f", stats.getTotal_distance_km()));
        tvAverageFare.setText(String. format(Locale.getDefault(), "%,d", stats.getAverage_fare()));

        // Detailed Statistics
        int hours = stats.getTotal_duration_minutes() / 60;
        int minutes = stats.getTotal_duration_minutes() % 60;
        tvTotalDuration.setText(String.format(Locale. getDefault(), "%dh %dmin", hours, minutes));

        tvFareCollectionRate.setText(String.format(Locale.getDefault(), "%.1f%%",
                                                   stats.getFare_collection_rate()));

        tvFaresCollected. setText(String.format(Locale.getDefault(), "%d / %d",
                                               stats.getFare_collected_count(),
                                               stats.getTotal_journeys()));

        tvBusiestDestination.setText(stats.getBusiest_destination() != null ?
                                    stats.getBusiest_destination() : "N/A");
    }

    private void showLoading(boolean show) {
        loadingOverlay.setVisibility(show ? View.VISIBLE : View.GONE);
    }
}
