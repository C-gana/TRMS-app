package com.trms.driver.ui.history;

import android.os.Bundle;
import android.view.View;
import android.widget. FrameLayout;
import android. widget.ImageView;
import android.widget.TextView;
import android.widget.Toast;
import androidx.appcompat.app.AppCompatActivity;
import androidx.core.content.ContextCompat;
import androidx.lifecycle.LiveData;
import com.google.android.material.appbar. MaterialToolbar;
import com. trms.driver.R;
import com.trms.driver.data.local.TokenManager;
import com.trms.driver.data.model.Journey;
import com.trms.driver.data. repository.JourneyHistoryRepository;
import com.trms. driver.utils.DateUtils;
import java.text.SimpleDateFormat;
import java.util.Date;
import java.util.Locale;

public class JourneyDetailActivity extends AppCompatActivity {

    // UI Components
    private MaterialToolbar toolbar;
    private TextView tvJourneyId, tvJourneyDate;
    private TextView tvPassengerName, tvPassengerPhone;
    private TextView tvBoardingLocation, tvBoardingTime;
    private TextView tvAlightingLocation, tvAlightingTime;
    private TextView tvDuration, tvDistanceValue, tvFareValue;
    private TextView tvFareStatus;
    private ImageView ivFareStatusIcon;
    private FrameLayout loadingOverlay;

    // Data
    private JourneyHistoryRepository repository;
    private TokenManager tokenManager;
    private int journeyId;

    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);
        setContentView(R. layout.activity_journey_detail);

        // Get journey ID from intent
        journeyId = getIntent().getIntExtra("journey_id", -1);
        if (journeyId == -1) {
            Toast.makeText(this, "Invalid journey", Toast.LENGTH_SHORT).show();
            finish();
            return;
        }

        // Initialize
        tokenManager = new TokenManager(this);
        repository = new JourneyHistoryRepository(tokenManager);

        // Initialize views
        initializeViews();

        // Setup toolbar
        setupToolbar();

        // Load journey details
        loadJourneyDetails();
    }

    private void initializeViews() {
        toolbar = findViewById(R.id.toolbar);
        tvJourneyId = findViewById(R.id.tvJourneyId);
        tvJourneyDate = findViewById(R.id.tvJourneyDate);
        tvPassengerName = findViewById(R.id.tvPassengerName);
        tvPassengerPhone = findViewById(R.id.tvPassengerPhone);
        tvBoardingLocation = findViewById(R.id.tvBoardingLocation);
        tvBoardingTime = findViewById(R.id.tvBoardingTime);
        tvAlightingLocation = findViewById(R.id.tvAlightingLocation);
        tvAlightingTime = findViewById(R.id.tvAlightingTime);
        tvDuration = findViewById(R.id.tvDuration);
        tvDistanceValue = findViewById(R.id.tvDistanceValue);
        tvFareValue = findViewById(R.id. tvFareValue);
        tvFareStatus = findViewById(R. id.tvFareStatus);
        ivFareStatusIcon = findViewById(R.id.ivFareStatusIcon);
        loadingOverlay = findViewById(R.id. loadingOverlay);
    }

    private void setupToolbar() {
        setSupportActionBar(toolbar);
        if (getSupportActionBar() != null) {
            getSupportActionBar().setDisplayHomeAsUpEnabled(true);
        }
        toolbar. setNavigationOnClickListener(v -> onBackPressed());
    }

    private void loadJourneyDetails() {
        showLoading(true);

        LiveData<JourneyHistoryRepository.Result<Journey>> result =
            repository.getJourneyDetail(journeyId);

        result.observeForever(journeyResult -> {
            showLoading(false);

            if (journeyResult.isSuccess()) {
                displayJourneyDetails(journeyResult.getData());
            } else {
                Toast.makeText(this, journeyResult.getError(), Toast.LENGTH_SHORT).show();
                finish();
            }
        });
    }

    private void displayJourneyDetails(Journey journey) {
        // Journey ID and Date
        tvJourneyId. setText(String.format(Locale.getDefault(), "#%d", journey.getJourney_id()));

        try {
            SimpleDateFormat inputFormat = new SimpleDateFormat("yyyy-MM-dd'T'HH:mm:ss", Locale.getDefault());
            SimpleDateFormat outputFormat = new SimpleDateFormat("dd MMM yyyy", Locale.getDefault());
            Date date = inputFormat.parse(journey.getBoarding_time());
            if (date != null) {
                tvJourneyDate.setText(outputFormat.format(date));
            }
        } catch (Exception e) {
            tvJourneyDate.setText("");
        }

        // Passenger Information
        tvPassengerName. setText(journey.getPassenger_name() != null ?
                               journey.getPassenger_name() : "N/A");
        tvPassengerPhone.setText(journey.getPassenger_phone() != null ?
                                journey.getPassenger_phone() : "N/A");

        // Boarding Location
        if (journey.getBoarding_location() != null &&
            journey.getBoarding_location().getAddress() != null) {
            tvBoardingLocation.setText(journey.getBoarding_location().getAddress());
        } else {
            tvBoardingLocation.setText("Location unavailable");
        }
        tvBoardingTime.setText(DateUtils.formatTime(journey.getBoarding_time()));

        // Alighting Location
        if (journey.getAlighting_location() != null &&
            journey.getAlighting_location().getAddress() != null) {
            tvAlightingLocation.setText(journey.getAlighting_location().getAddress());
        } else {
            tvAlightingLocation.setText(journey.getDestination());
        }
        tvAlightingTime.setText(DateUtils. formatTime(journey.getAlighting_time()));

        // Journey Statistics
        tvDuration.setText(String.valueOf(journey.getDuration_minutes()));
        tvDistanceValue.setText(String.format(Locale.getDefault(), "%.1f", journey.getDistance_km()));
        tvFareValue. setText(String.format(Locale.getDefault(), "%,d", journey.getFare()));

        // Fare Collection Status
        if (journey.isFare_collected()) {
            tvFareStatus.setText(R.string.fare_collected);
            tvFareStatus.setTextColor(ContextCompat.getColor(this, R.color.fare_collected));
            ivFareStatusIcon.setImageResource(R.drawable.ic_check_circle);
            ivFareStatusIcon.setColorFilter(ContextCompat.getColor(this, R.color. fare_collected));
        } else {
            tvFareStatus.setText(R. string.fare_not_collected);
            tvFareStatus.setTextColor(ContextCompat. getColor(this, R.color.fare_not_collected));
            ivFareStatusIcon.setImageResource(R.drawable.ic_warning);
            ivFareStatusIcon.setColorFilter(ContextCompat.getColor(this, R.color.fare_not_collected));
        }
    }

    private void showLoading(boolean show) {
        loadingOverlay. setVisibility(show ? View. VISIBLE : View.GONE);
    }
}
