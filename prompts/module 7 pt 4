package com.trms.driver.ui.settings;

import android.app.Dialog;
import android.content.Context;
import android.os.Bundle;
import android.view. LayoutInflater;
import android. view.View;
import android. widget.RadioButton;
import android.widget. RadioGroup;
import androidx.annotation.NonNull;
import com.google.android.material.button.MaterialButton;
import com. google.android.material.dialog.MaterialAlertDialogBuilder;
import com.trms.driver.R;
import com.trms. driver.data.local.PreferencesManager;

public class ThemeSelectionDialog extends Dialog {

    public interface OnThemeChangedListener {
        void onThemeChanged();
    }

    private PreferencesManager preferencesManager;
    private OnThemeChangedListener listener;
    private int selectedTheme;

    public ThemeSelectionDialog(@NonNull Context context, PreferencesManager preferencesManager) {
        super(context);
        this.preferencesManager = preferencesManager;
        this.selectedTheme = preferencesManager.getThemeMode();
    }

    public void setOnThemeChangedListener(OnThemeChangedListener listener) {
        this.listener = listener;
    }

    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);

        // Inflate layout
        LayoutInflater inflater = LayoutInflater.from(getContext());
        View view = inflater.inflate(R. layout.dialog_theme_selection, null);

        // Setup views
        RadioGroup radioGroupTheme = view.findViewById(R.id.radioGroupTheme);
        RadioButton radioLight = view.findViewById(R.id.radioLight);
        RadioButton radioDark = view.findViewById(R.id.radioDark);
        RadioButton radioSystem = view.findViewById(R.id.radioSystem);
        MaterialButton btnCancel = view.findViewById(R. id.btnCancel);
        MaterialButton btnApply = view.findViewById(R.id.btnApply);

        // Set current selection
        switch (selectedTheme) {
            case PreferencesManager.THEME_LIGHT:
                radioLight.setChecked(true);
                break;
            case PreferencesManager.THEME_DARK:
                radioDark.setChecked(true);
                break;
            case PreferencesManager. THEME_SYSTEM:
            default:
                radioSystem.setChecked(true);
                break;
        }

        // Radio group listener
        radioGroupTheme.setOnCheckedChangeListener((group, checkedId) -> {
            if (checkedId == R.id.radioLight) {
                selectedTheme = PreferencesManager. THEME_LIGHT;
            } else if (checkedId == R.id.radioDark) {
                selectedTheme = PreferencesManager.THEME_DARK;
            } else if (checkedId == R.id. radioSystem) {
                selectedTheme = PreferencesManager. THEME_SYSTEM;
            }
        });

        // Button listeners
        btnCancel. setOnClickListener(v -> dismiss());

        btnApply.setOnClickListener(v -> {
            preferencesManager.setThemeMode(selectedTheme);
            if (listener != null) {
                listener.onThemeChanged();
            }
            dismiss();
        });

        // Set view
        setContentView(view);
    }
}
