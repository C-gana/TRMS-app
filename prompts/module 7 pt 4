package com.trms.driver.ui.settings;

import android.os.Bundle;
import android.widget.CompoundButton;
import androidx.appcompat.app.AppCompatActivity;
import com.google.android.material.appbar.MaterialToolbar;
import com.google.android.material. switchmaterial.SwitchMaterial;
import com.trms. driver.R;
import com. trms.driver.data.local.PreferencesManager;

public class NotificationSettingsActivity extends AppCompatActivity {

    private MaterialToolbar toolbar;
    private SwitchMaterial switchEnableAll, switchProximity, switchBoarding;
    private SwitchMaterial switchJourneyCompleted, switchSound, switchVibration;

    private PreferencesManager preferencesManager;

    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);
        setContentView(R.layout.activity_notification_settings);

        // Initialize
        preferencesManager = new PreferencesManager(this);

        // Initialize views
        initializeViews();

        // Setup toolbar
        setupToolbar();

        // Load preferences
        loadPreferences();

        // Setup listeners
        setupListeners();
    }

    private void initializeViews() {
        toolbar = findViewById(R.id.toolbar);
        switchEnableAll = findViewById(R.id.switchEnableAll);
        switchProximity = findViewById(R.id. switchProximity);
        switchBoarding = findViewById(R.id.switchBoarding);
        switchJourneyCompleted = findViewById(R.id.switchJourneyCompleted);
        switchSound = findViewById(R.id.switchSound);
        switchVibration = findViewById(R.id.switchVibration);
    }

    private void setupToolbar() {
        setSupportActionBar(toolbar);
        if (getSupportActionBar() != null) {
            getSupportActionBar().setDisplayHomeAsUpEnabled(true);
        }
        toolbar.setNavigationOnClickListener(v -> onBackPressed());
    }

    private void loadPreferences() {
        switchEnableAll.setChecked(preferencesManager.isNotificationsEnabled());
        switchProximity.setChecked(preferencesManager.isProximityAlertsEnabled());
        switchBoarding.setChecked(preferencesManager.isBoardingNotificationsEnabled());
        switchJourneyCompleted.setChecked(preferencesManager.isJourneyCompletedNotificationsEnabled());
        switchSound.setChecked(preferencesManager.isNotificationSoundEnabled());
        switchVibration.setChecked(preferencesManager.isNotificationVibrationEnabled());

        // Enable/disable individual switches based on master switch
        updateIndividualSwitches(switchEnableAll. isChecked());
    }

    private void setupListeners() {
        // Master switch
        switchEnableAll. setOnCheckedChangeListener((buttonView, isChecked) -> {
            preferencesManager.setNotificationsEnabled(isChecked);
            updateIndividualSwitches(isChecked);
        });

        // Individual notification types
        switchProximity.setOnCheckedChangeListener((buttonView, isChecked) ->
            preferencesManager.setProximityAlertsEnabled(isChecked)
        );

        switchBoarding.setOnCheckedChangeListener((buttonView, isChecked) ->
            preferencesManager.setBoardingNotificationsEnabled(isChecked)
        );

        switchJourneyCompleted.setOnCheckedChangeListener((buttonView, isChecked) ->
            preferencesManager. setJourneyCompletedNotificationsEnabled(isChecked)
        );

        // Sound settings
        switchSound.setOnCheckedChangeListener((buttonView, isChecked) ->
            preferencesManager.setNotificationSoundEnabled(isChecked)
        );

        switchVibration.setOnCheckedChangeListener((buttonView, isChecked) ->
            preferencesManager.setNotificationVibrationEnabled(isChecked)
        );
    }

    private void updateIndividualSwitches(boolean enabled) {
        switchProximity.setEnabled(enabled);
        switchBoarding.setEnabled(enabled);
        switchJourneyCompleted.setEnabled(enabled);
        switchSound.setEnabled(enabled);
        switchVibration.setEnabled(enabled);
    }
}
