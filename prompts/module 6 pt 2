```java
package com.trms.driver.data.repository;

import android.content.Context;
import androidx.lifecycle.LiveData;
import androidx. lifecycle.MediatorLiveData;
import androidx.lifecycle.MutableLiveData;
import com.trms.driver.data. api.DashboardApiService;
import com.trms.driver. data.api.RetrofitClient;
import com.trms. driver.data.local.TRMSDatabase;
import com. trms.driver.data.local.TokenManager;
import com. trms.driver.data.local.dao.DashboardCacheDao;
import com.trms.driver.data.local.entity.DashboardCacheEntity;
import com.trms.driver.data.model.*;
import com.trms.driver.sync.SyncManager;
import com.trms.driver.utils. NetworkMonitor;
import retrofit2.Call;
import retrofit2.Callback;
import retrofit2.Response;
import java.util.concurrent.ExecutorService;
import java.util.concurrent.Executors;

public class DashboardRepository {

    private DashboardApiService apiService;
    private TokenManager tokenManager;
    private DashboardCacheDao cacheDao;
    private NetworkMonitor networkMonitor;
    private SyncManager syncManager;
    private ExecutorService executorService;

    public DashboardRepository(Context context, TokenManager tokenManager) {
        this.apiService = RetrofitClient.getInstance().getDashboardApi();
        this.tokenManager = tokenManager;
        this.cacheDao = TRMSDatabase.getInstance(context).dashboardCacheDao();
        this.networkMonitor = new NetworkMonitor(context);
        this.syncManager = new SyncManager(context);
        this.executorService = Executors.newSingleThreadExecutor();
    }

    /**
     * Get dashboard with offline support
     */
    public LiveData<Result<DashboardResponse>> getDashboard(String vehicleId) {
        MediatorLiveData<Result<DashboardResponse>> result = new MediatorLiveData<>();

        // Check network status
        Boolean isConnected = networkMonitor. isConnected().getValue();

        if (isConnected != null && isConnected) {
            // ONLINE:  Fetch from API
            fetchDashboardFromAPI(vehicleId, result);
        } else {
            // OFFLINE: Load from cache
            loadDashboardFromCache(result);
        }

        return result;
    }

    private void fetchDashboardFromAPI(String vehicleId, MediatorLiveData<Result<DashboardResponse>> result) {
        String token = tokenManager.getToken();
        if (token == null) {
            result.setValue(Result.error("Authentication required", true));
            return;
        }

        apiService.getDashboard(vehicleId, "Bearer " + token)
            .enqueue(new Callback<DashboardResponse>() {
                @Override
                public void onResponse(Call<DashboardResponse> call, Response<DashboardResponse> response) {
                    if (response.isSuccessful() && response.body() != null) {
                        DashboardResponse data = response.body();

                        // Cache the data
                        cacheDashboard(data);

                        result.setValue(Result.success(data, true));
                    } else {
                        // API error, try cache as fallback
                        loadDashboardFromCache(result);
                    }
                }

                @Override
                public void onFailure(Call<DashboardResponse> call, Throwable t) {
                    // Network error, load from cache
                    loadDashboardFromCache(result);
                }
            });
    }

    private void loadDashboardFromCache(MediatorLiveData<Result<DashboardResponse>> result) {
        executorService.execute(() -> {
            DashboardCacheEntity cached = cacheDao.getDashboard();

            if (cached != null) {
                // Convert cached entity to DashboardResponse
                DashboardResponse response = new DashboardResponse();
                response.setSuccess(true);
                response.setVehicle_id(cached.getVehicle_id());
                response.setRegistration(cached.getRegistration());
                response.setActive_journeys(cached.getActive_journeys());
                response.setSeats(cached.getSeats());
                response.setTodays_stats(cached.getTodays_stats());

                result.postValue(Result. success(response, false)); // false = from cache
            } else {
                result.postValue(Result.error("No cached data available", false));
            }
        });
    }

    private void cacheDashboard(DashboardResponse data) {
        executorService.execute(() -> {
            try {
                DashboardCacheEntity entity = new DashboardCacheEntity();
                entity.setId(1);
                entity.setVehicle_id(data.getVehicle_id());
                entity.setRegistration(data.getRegistration());
                entity.setActive_journeys(data.getActive_journeys());
                entity.setSeats(data.getSeats());
                entity.setTodays_stats(data.getTodays_stats());
                entity.setCached_at(System.currentTimeMillis());

                cacheDao.insertDashboard(entity);
            } catch (Exception e) {
                // Log error
            }
        });
    }

    /**
     * Record boarding with offline support
     */
    public LiveData<Result<BoardingResponse>> recordBoarding(String vehicleId, int seatNumber,
                                                              Location location) {
        MutableLiveData<Result<BoardingResponse>> result = new MutableLiveData<>();

        String token = tokenManager.getToken();
        if (token == null) {
            result.setValue(Result.error("Authentication required", true));
            return result;
        }

        BoardingRequest request = new BoardingRequest(vehicleId, seatNumber, location);

        Boolean isConnected = networkMonitor. isConnected().getValue();

        if (isConnected != null && isConnected) {
            // ONLINE: Send immediately
            apiService.recordBoarding(request, "Bearer " + token)
                .enqueue(new Callback<BoardingResponse>() {
                    @Override
                    public void onResponse(Call<BoardingResponse> call, Response<BoardingResponse> response) {
                        if (response.isSuccessful() && response.body() != null) {
                            result.setValue(Result.success(response.body(), true));
                        } else {
                            result.setValue(Result. error("Boarding failed", true));
                        }
                    }

                    @Override
                    public void onFailure(Call<BoardingResponse> call, Throwable t) {
                        // Queue for later sync
                        syncManager.queueOperation("BOARDING", request);
                        result.setValue(Result.queued("Boarding queued for sync", false));
                    }
                });
        } else {
            // OFFLINE: Queue operation
            syncManager.queueOperation("BOARDING", request);
            result.setValue(Result.queued("Boarding queued for sync", false));
        }

        return result;
    }

    public NetworkMonitor getNetworkMonitor() {
        return networkMonitor;
    }

    public SyncManager getSyncManager() {
        return syncManager;
    }

    // Enhanced Result wrapper
    public static class Result<T> {
        private T data;
        private String error;
        private boolean success;
        private boolean fromNetwork;
        private boolean queued;

        private Result(T data, String error, boolean success, boolean fromNetwork, boolean queued) {
            this.data = data;
            this.error = error;
            this.success = success;
            this.fromNetwork = fromNetwork;
            this.queued = queued;
        }

        public static <T> Result<T> success(T data, boolean fromNetwork) {
            return new Result<>(data, null, true, fromNetwork, false);
        }

        public static <T> Result<T> error(String error, boolean fromNetwork) {
            return new Result<>(null, error, false, fromNetwork, false);
        }

        public static <T> Result<T> queued(String message, boolean fromNetwork) {
            return new Result<>(null, message, true, fromNetwork, true);
        }

        public T getData() { return data; }
        public String getError() { return error; }
        public boolean isSuccess() { return success; }
        public boolean isFromNetwork() { return fromNetwork; }
        public boolean isQueued() { return queued; }
    }
}
