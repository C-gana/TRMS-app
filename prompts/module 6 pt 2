## Feature 15: Schedule Background Sync

**Update TRMSApplication.java:**

```java
package com.trms.driver;

import android.app.Application;
import androidx.work.*;
import com.trms.driver. data.local.PreferencesManager;
import com.trms. driver.sync.SyncWorker;
import java.util.concurrent.TimeUnit;

public class TRMSApplication extends Application {

    public static final String CHANNEL_ID = "trms_driver_channel";
    private static final String SYNC_WORK_TAG = "trms_sync_work";

    @Override
    public void onCreate() {
        super.onCreate();

        // Initialize theme
        PreferencesManager preferencesManager = new PreferencesManager(this);
        preferencesManager.applyTheme(preferencesManager.getThemeMode());

        // Schedule periodic sync
        schedulePeriodicSync();

        // Create notification channels (existing code)
        // ...
    }

    private void schedulePeriodicSync() {
        Constraints constraints = new Constraints.Builder()
            .setRequiredNetworkType(NetworkType. CONNECTED)
            .build();

        PeriodicWorkRequest syncWorkRequest = new PeriodicWorkRequest.Builder(
            SyncWorker.class,
            15, TimeUnit.MINUTES // Sync every 15 minutes when online
        )
            .setConstraints(constraints)
            .addTag(SYNC_WORK_TAG)
            .setBackoffCriteria(
                BackoffPolicy.EXPONENTIAL,
                10, TimeUnit. MINUTES
            )
            .build();

        WorkManager.getInstance(this).enqueueUniquePeriodicWork(
            SYNC_WORK_TAG,
            ExistingPeriodicWorkPolicy.KEEP,
            syncWorkRequest
        );
    }
}
