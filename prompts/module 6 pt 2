// Add to MainActivity. java

// Add member variables
private NetworkMonitor networkMonitor;
private SyncManager syncManager;
private LinearLayout offlineBanner, syncIndicator;
private TextView tvOfflineMessage, tvPendingSync, tvSyncMessage;

// In onCreate(), after initializing repository:
networkMonitor = repository.getNetworkMonitor();
syncManager = repository.getSyncManager();

// Initialize offline indicators
offlineBanner = findViewById(R.id.offlineBanner);
syncIndicator = findViewById(R.id.syncIndicator);
tvOfflineMessage = findViewById(R.id.tvOfflineMessage);
tvPendingSync = findViewById(R.id. tvPendingSync);
tvSyncMessage = findViewById(R.id.tvSyncMessage);

// Observe network status
observeNetworkStatus();

// Observe sync status
observeSyncStatus();

// Add these new methods:

private void observeNetworkStatus() {
    networkMonitor.isConnected().observe(this, isConnected -> {
        if (isConnected != null) {
            if (isConnected) {
                // ONLINE
                offlineBanner.setVisibility(View.GONE);

                // Trigger auto-sync if there are pending operations
                Integer pendingCount = syncManager.getPendingOperationsCount().getValue();
                if (pendingCount != null && pendingCount > 0) {
                    syncManager.syncPendingOperations();
                }
            } else {
                // OFFLINE
                offlineBanner.setVisibility(View.VISIBLE);
                tvOfflineMessage.setText(R.string.offline_mode_message);
            }
        }
    });
}

private void observeSyncStatus() {
    // Observe sync status
    syncManager.getSyncStatus().observe(this, status -> {
        switch (status) {
            case SYNCING:
                syncIndicator.setVisibility(View.VISIBLE);
                tvSyncMessage.setText(R.string.syncing_data);
                break;

            case SUCCESS:
                syncIndicator.setVisibility(View.GONE);
                Toast.makeText(this, R. string.sync_complete, Toast.LENGTH_SHORT).show();

                // Refresh dashboard after sync
                viewModel.refreshNow();
                break;

            case ERROR:
                syncIndicator.setVisibility(View.GONE);
                Toast.makeText(this, R. string.sync_error, Toast. LENGTH_SHORT).show();
                break;

            case IDLE:
            default:
                syncIndicator. setVisibility(View.GONE);
                break;
        }
    });

    // Observe pending operations count
    syncManager.getPendingOperationsCount().observe(this, count -> {
        if (count != null && count > 0) {
            tvPendingSync.setVisibility(View.VISIBLE);
            tvPendingSync. setText(getResources().getQuantityString(
                R.plurals.pending_operations, count, count));
        } else {
            tvPendingSync.setVisibility(View.GONE);
        }
    });
}

// Update observeViewModel to handle offline results:
private void observeViewModel() {
    viewModel.getDashboardState().observe(this, state -> {
        switch (state. getStatus()) {
            case LOADING:
                // Show loading
                break;

            case SUCCESS:
                swipeRefresh.setRefreshing(false);
                updateDashboard(state.getData());

                // Check if data is from cache
                if (state.getData() != null && ! state.isFromNetwork()) {
                    tvLastUpdated.setText(R.string.showing_cached_data);
                } else {
                    tvLastUpdated.setText(R.string. last_updated_now);
                }
                break;

            case ERROR:
                swipeRefresh.setRefreshing(false);
                showError(state.getError());
                break;
        }
    });

    // Update boarding state observer to handle queued operations
    viewModel.getBoardingState().observe(this, state -> {
        switch (state. getStatus()) {
            case LOADING:
                showLoading(true);
                break;

            case SUCCESS:
                showLoading(false);

                if (state.isQueued()) {
                    // Operation queued
                    Toast.makeText(this, R. string.operation_queued, Toast.LENGTH_SHORT).show();
                } else {
                    // Immediate success
                    BoardingResponse response = state.getData();
                    Toast.makeText(this, response.getMessage(), Toast.LENGTH_SHORT).show();

                    // Launch destination selection
                    launchDestinationSelection(
                        response.getJourney_id(),
                        response.getSeat_number()
                    );
                }
                break;

            case ERROR:
                showLoading(false);
                showBoardingError(state.getError());
                break;
        }
    });
}

@Override
protected void onDestroy() {
    super.onDestroy();
    if (networkMonitor != null) {
        networkMonitor.unregister();
    }
}
